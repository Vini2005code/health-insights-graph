# ===============================
# Primordial Data — Backend (FastAPI + GROQ)
# Copie este arquivo para `.env` e preencha os valores reais.
# ===============================

# --- Banco de dados Postgres ---
# Formato: postgresql+asyncpg://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Exemplo local:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/primordial_data
# Exemplo Supabase (usar o pooler com ?ssl=true):
#   postgresql+asyncpg://postgres:SENHA@db.xxxxx.supabase.co:5432/postgres?ssl=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/primordial_data

# Cria as tabelas automaticamente no startup (true/false).
# Em produção, prefira usar Alembic e deixar como false.
AUTO_CREATE_TABLES=true

# --- GROQ ---
# Pegue sua chave em: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS ---
# Origem do frontend Vite em dev. Separe múltiplas por vírgula.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Server ---
HOST=0.0.0.0
PORT=8000